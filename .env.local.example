# Neon PostgreSQL
DATABASE_URL=

# CSG API
CSGAPI=

# Twilio (SMS verification)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Make.com webhook (call-me requests)
MAKE_WEBHOOK_URL=

# Make.com webhook (GHL lead sync on phone verification)
GHL_WEBHOOK_URL=

# Facebook CAPI (server-side only, no pixel script)
META_PIXEL_ID=
META_CAPI_TOKEN=

# Dental funnel — Meta Pixel + Conversions API (separate dental campaign pixel)
DENTAL_META_PIXEL_ID=1405157201420637
DENTAL_META_CAPI_TOKEN=

# Dental funnel — GHL inbound webhook (falls back to GHL_WEBHOOK_URL). Optional.
GHL_DENTAL_WEBHOOK_URL=

# Dental funnel — Google Maps Places API key (address autocomplete on enrollment)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Bonus carrier prioritization (set carrier display name to prioritize, leave blank to disable)
BONUS_CARRIER_NAME=
BONUS_CARRIER_MIN_SAVINGS=40
BONUS_CARRIER_MAX_DELTA=10

# PostHog analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
